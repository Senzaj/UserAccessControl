.vs/
*_i.c
*_p.c
*.ncb
*.suo

*.tlb
*.tlh
*.bak
*.cache
*.ilk

*.log
*.lib
*.sbr
*.sdf
packages/

TestResults/
[Bb]in/
[Dd]ebug/
[Rr]elease/

### Asp_net ###
# asp_net specific files

bin/
obj/
*.user
*.suo
*.pdb

*.cache
*.log

